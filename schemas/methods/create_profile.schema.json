{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://keyforge.dev/schemas/v1/methods/create_profile.schema.json",
  "title": "Method: create_profile",
  "description": "Creates a new profile. The server generates the id and returns the profile with an empty bindings array.",
  "type": "object",
  "additionalProperties": false,
  "required": ["params", "result"],
  "properties": {
    "params": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name"],
      "properties": {
        "name": {
          "type": "string",
          "description": "Human-friendly name for the new profile.",
          "minLength": 1
        }
      }
    },
    "result": {
      "type": "object",
      "additionalProperties": false,
      "required": ["profile"],
      "properties": {
        "profile": { "$ref": "../common.schema.json#/$defs/Profile" }
      }
    }
  }
}
