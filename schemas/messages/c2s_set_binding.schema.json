{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://keyforge.dev/schemas/v1/messages/c2s_set_binding.json",
  "title": "C2S: SetBinding",
  "description": "Sent by GUI to daemon to create or update a binding.",
  "type": "object",
  "additionalProperties": false,
  "required": ["msg", "id", "payload"],
  "properties": {
    "msg":     { "const": "set_binding" },
    "id":      {
      "type": "string",
      "description": "Correlation ID set by the client; daemon echoes it on the ack."
    },
    "payload": { "$ref": "https://keyforge.dev/schemas/v1/common.json#/$defs/Binding" }
  }
}
