{
  "name": "@jdg-keyforge/protocol",
  "version": "0.8.0",
  "description": "TypeScript types for the KeyForge WebSocket protocol, generated from the canonical JSON Schema contracts.",
  "keywords": ["keyforge", "protocol", "types", "json-schema", "websocket"],
  "license": "Apache-2.0",
  "author": "Jonathan Daniel Gomez <jonathan.d.gomez98@gmail.com>",
  "homepage": "https://github.com/JoniDG/keyforge-protocol",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JoniDG/keyforge-protocol.git",
    "directory": "ts"
  },
  "bugs": {
    "url": "https://github.com/JoniDG/keyforge-protocol/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  }
}
